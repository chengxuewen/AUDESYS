{
  "name": "audesys-il-editor",
  "version": "0.1.0",
  "private": true,
  "description": "AUDESYS IL Editor — Theia extension with Monarch tokenizer and completion for IEC 61131-3 Instruction List",
  "license": "Apache-2.0",
  "keywords": [
    "theia-extension"
  ],
  "main": "lib/browser/index.js",
  "theiaExtensions": [
    {
      "frontend": "lib/browser/index"
    }
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib",
    "watch": "tsc -b -w",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@theia/core": "1.73.0",
    "@theia/monaco": "1.73.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
