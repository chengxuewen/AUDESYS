{
  "name": "audesys-debug",
  "version": "0.1.0",
  "private": true,
  "description": "AUDESYS Debug Panel — Theia debug adapter for Controller DAP bridge",
  "license": "Apache-2.0",
  "keywords": [
    "theia-extension"
  ],
  "main": "lib/browser/index.js",
  "theiaExtensions": [
    {
      "frontend": "lib/browser/index"
    }
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib",
    "watch": "tsc -b -w",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@rolldown/binding-darwin-x64": "^1.2.0",
    "@theia/core": "1.73.0",
    "@theia/debug": "1.73.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
