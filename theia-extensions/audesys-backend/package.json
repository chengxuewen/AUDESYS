  },
  "peerDependencies": {
    "@theia/core": "1.73.0"
  },
  "devDependencies": {
    "@types/winston": "^2.4.4",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
