{
  "name": "audesys-backend",
  "version": "0.1.0",
  "private": true,
  "description": "AUDESYS Studio Backend — JSON-RPC proxy bridging Theia frontend to napi-rs Rust backend",
  "license": "Apache-2.0",
  "main": "lib/node/index.js",
  "theiaExtensions": [
    {
      "backend": "lib/node/index"
    }
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib",
